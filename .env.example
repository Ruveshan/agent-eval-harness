# Copy to .env (or export directly) before running the live agent.
# The dashboard and unit tests do NOT need any key — only `python -m harness run`.

# Default agent (--agent gemini). FREE key, no card required:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-free-gemini-key-here

# Optional: pick the Gemini model (default: gemini-3.1-flash-lite —
# empirically the model whose free-tier quota sustains a full suite run)
# GEMINI_MODEL=gemini-2.5-flash

# Only needed for `--agent claude` (paid):
# ANTHROPIC_API_KEY=sk-ant-your-key-here
